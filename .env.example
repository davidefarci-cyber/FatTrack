# Copia questo file in `.env` e compila i valori.
# Tutte le variabili esposte al client devono avere prefisso EXPO_PUBLIC_.

# --- App ---
EXPO_PUBLIC_APP_ENV=development

# --- API pubbliche per dati nutrizionali ---
# Open Food Facts non richiede chiave, ma puoi personalizzare lo User-Agent.
EXPO_PUBLIC_OPENFOODFACTS_BASE_URL=https://world.openfoodfacts.org
EXPO_PUBLIC_OPENFOODFACTS_USER_AGENT=FatTrack/0.1 (dev)

# --- Backend opzionale ---
EXPO_PUBLIC_API_BASE_URL=
EXPO_PUBLIC_API_KEY=

# --- Analytics / monitoring (opzionali) ---
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# --- EAS ---
# Impostato automaticamente da `eas build:configure`; riportato qui per riferimento.
EAS_PROJECT_ID=
