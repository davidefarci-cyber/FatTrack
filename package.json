{
  "name": "fattrack",
  "version": "0.1.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "prebuild": "expo prebuild",
    "build:android:preview": "eas build --platform android --profile preview",
    "build:android:production": "eas build --platform android --profile production",
    "build:android:local:preview": "eas build --platform android --profile preview --local",
    "build:android:local:production": "eas build --platform android --profile production --local",
    "update:ota": "eas update --branch production"
  },
  "dependencies": {
    "@expo-google-fonts/plus-jakarta-sans": "^0.2.3",
    "@react-native-async-storage/async-storage": "1.23.1",
